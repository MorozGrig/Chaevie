<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FirstFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/bill_amount_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bill_amount_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/tip_percent_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tip_percent_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                android:text="15" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/people_count_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/people_count_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                android:text="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/rounding_title"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <RadioGroup
            android:id="@+id/rounding_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checkedButton="@id/rounding_floor_radio_button">

            <RadioButton
                android:id="@+id/rounding_floor_radio_button"
                android:layout_width="match_parent"
                android:layout_height="61dp"
                android:text="@string/rounding_floor" />

            <RadioButton
                android:id="@+id/rounding_ceil_radio_button"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="@string/rounding_ceil" />

            <RadioButton
                android:id="@+id/rounding_round_radio_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rounding_round" />
        </RadioGroup>

        <Button
            android:id="@+id/calculate_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/calculate" />

        <TextView
            android:id="@+id/error_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="?attr/colorError"
            android:visibility="gone"
            tools:text="Ошибка ввода"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/results_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tip_amount_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                tools:text="Чаевые: 125.00" />

            <TextView
                android:id="@+id/total_amount_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                tools:text="Итого: 1125.00" />

            <TextView
                android:id="@+id/amount_per_person_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                tools:text="На человека: 562.50" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
